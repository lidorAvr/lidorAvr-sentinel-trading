<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<title>Sentinel — דוח שבועי {{ period_label }}</title>
<style>{{ base_css }}</style>
</head>
<body>

{# Running header for all pages after cover #}
<div id="page-header">🛡️ Sentinel Trading | דוח שבועי {{ period_label }} | הופק: <span class="ltr">{{ generated_at[:10] }}</span></div>

{# ══ PAGE 1: Executive Summary ══════════════════════════════════════════════ #}
<div class="cover-header">
  <div class="system-name">🛡️ Sentinel Trading</div>
  <div class="report-type">דוח שבועי</div>
  <div class="period-label"><span class="ltr">{{ period_label }}</span></div>
</div>

<div class="freshness-banner freshness-{{ freshness }}">{{ freshness_label }}</div>

{# Sprint-19 §1a/§1b — period-honest headline. Trigger (headline_open_book_mode)
   = 0 campaigns closed AND a Sprint-18-wired LIVE book spanned the period.
   When triggered the dominant verdict-badge is SUPPRESSED (compute_verdict
   return value, verdict_class, _base_ctx realized keys all byte-identical —
   the template merely chooses which to show) and REPLACED by Mark's
   period-honest badge + the promoted open-book banner. ALGO is on its OWN
   segregated line inside the banner, NEVER in the headline #. Truly-empty
   (§1d) / non-zero-campaign / legacy open_book-None callers keep the
   byte-identical legacy verdict path (920be95 / Sprint-16 intact). #}
{% if headline_open_book_mode %}
<div class="verdict-badge verdict-{{ headline_badge_class }}">{{ headline_badge_text }}</div>
<div class="freshness-banner freshness-unknown">
  {% for line in headline_banner_lines %}<div><span class="ltr">{{ line }}</span></div>{% endfor %}
</div>
{% else %}
<div class="verdict-badge verdict-{{ verdict_class }}">{{ verdict }}</div>

{# Sprint-18 Mark §2 — honest empty-state banner (PRESENTATION supplement,
   never a verdict-class change; never the word "ללא עסקאות" with a live book).
   Shown only when 0 campaigns closed AND the §1 headline did NOT take over
   (truly-empty §1d) — defensive, identical Sprint-18 output, no regression. #}
{% if ob_show_empty_state %}
<div class="freshness-banner freshness-unknown">
  {% for line in ob_empty_state_lines %}<div><span class="ltr">{{ line }}</span></div>{% endfor %}
</div>
{% endif %}
{% endif %}

{# Sprint-19 §1c — realized KPI cards are BYTE-IDENTICAL values; under the
   §1 trigger they are DEMOTED below the banner with a preceding honest
   sub-heading and the realized-PnL card label is reframed. Numbers never
   hidden, never altered, never spun. #}
{% if headline_open_book_mode %}
<div class="kpi-frame-note"><span class="ltr">{{ headline_realized_subheading }}</span></div>
{% endif %}
{# KPI cards — 3-column table #}
<table class="kpi-grid">
  <tr>
    <td class="kpi-card{% if realized_pnl >= 0 %} kpi-green{% elif realized_pnl < 0 %} kpi-red{% endif %}">
      <div class="kpi-label">{% if headline_open_book_mode %}{{ headline_realized_pnl_label }}{% else %}רווח ממומש{% endif %}</div>
      <div class="kpi-value ltr">{% if realized_pnl >= 0 %}+{% endif %}${{ "%.0f"|format(realized_pnl) }}</div>
      <div class="kpi-sub"><span class="ltr">{{ "%.2f"|format(total_r_net) }}R</span></div>
    </td>
    <td class="kpi-card{% if win_rate >= 0.55 %} kpi-green{% elif win_rate < 0.4 %} kpi-red{% endif %}">
      <div class="kpi-label">Win Rate</div>
      <div class="kpi-value ltr">{{ "%.0f"|format(win_rate * 100) }}%</div>
      <div class="kpi-sub">{{ campaigns_closed }} קמפיינים</div>
    </td>
    <td class="kpi-card{% if expectancy_r >= 0.5 %} kpi-green{% elif expectancy_r < 0 %} kpi-red{% endif %}">
      <div class="kpi-label">Expectancy</div>
      <div class="kpi-value ltr">{{ "%+.2f"|format(expectancy_r) }}R</div>
      <div class="kpi-sub">לקמפיין ממוצע</div>
    </td>
  </tr>
  <tr>
    <td class="kpi-card">
      <div class="kpi-label">Profit Factor</div>
      <div class="kpi-value ltr">{{ "%.2f"|format(profit_factor) }}</div>
      <div class="kpi-sub">ניצחונות / הפסדים</div>
    </td>
    <td class="kpi-card">
      <div class="kpi-label">NAV</div>
      <div class="kpi-value ltr">${{ "{:,.0f}".format(nav) }}</div>
      <div class="kpi-sub">{{ nav_source }}{% if is_stale %} ⚠️{% endif %}</div>
    </td>
    <td class="kpi-card{% if dev_score is not none and dev_score >= 75 %} kpi-green{% elif dev_score is not none and dev_score < 50 %} kpi-red{% endif %}">
      <div class="kpi-label">ציון תהליך</div>
      <div class="kpi-value ltr">{% if dev_score is not none %}{{ dev_score }}/100{% else %}—{% endif %}</div>
      <div class="kpi-sub">{{ dev_label }}</div>
    </td>
  </tr>
</table>

{# ══ PAGE 2: Performance Breakdown ══════════════════════════════════════════ #}
<div class="page-break-before"></div>
<h2>📊 ניתוח ביצועים — <span class="ltr">{{ period_label }}</span></h2>

{% if chart_campaign_r %}
<div class="chart-wrap">
  <img src="{{ chart_campaign_r }}" alt="Net R לפי קמפיין" class="report-chart">
</div>
{% endif %}

{# Sprint-19 §2a — the existing "vs previous" column is unchanged; only the
   header is relabelled "(ממומש בלבד)" so it is never read as including the
   open book. §2b — ONE additive "מול ממוצע" column rendered only when
   cmp_vs_avg is available (N≥3); when < N the §2c baseline-pending token is
   shown ABOVE the table (text, never a number — #1). #}
{% if cmp_vs_avg_available %}
<p style="font-size:8.5pt; color:#374151;"><span class="ltr">{{ cmp_vs_avg_label }} (ממומש בלבד)</span></p>
{% elif cmp_vs_avg_baseline_pending %}
<p style="font-size:8.5pt; color:#374151;"><span class="ltr">{{ cmp_vs_avg_baseline_pending }}</span></p>
{% endif %}
<table class="metrics-table no-break">
  <tr><th>מדד</th><th>ערך</th>{% if comparison %}<th>{{ cmp_vs_prev_label }}</th>{% endif %}{% if cmp_vs_avg_available %}<th>{{ cmp_vs_avg_label }}</th>{% endif %}</tr>
  <tr>
    <td>קמפיינים שנסגרו</td>
    <td class="num">{{ campaigns_closed }}</td>
    {% if comparison and comparison.campaigns_closed is defined %}<td class="num {{ 'delta-up' if comparison.campaigns_closed.delta > 0 else 'delta-down' if comparison.campaigns_closed.delta < 0 else 'delta-flat' }}">{{ "%+d"|format(comparison.campaigns_closed.delta|int) }}</td>{% elif comparison %}<td>—</td>{% endif %}{% if cmp_vs_avg_available %}<td>—</td>{% endif %}
  </tr>
  <tr>
    <td>Win Rate</td>
    <td class="num {{ 'good' if win_rate >= 0.55 else 'bad' if win_rate < 0.4 else 'warn' }}"><span class="ltr">{{ "%.1f"|format(win_rate*100) }}%</span></td>
    {% if comparison and 'win_rate' in comparison %}<td class="num {{ 'delta-up' if comparison.win_rate.improving else 'delta-down' }}"><span class="ltr">{{ "%+.1f"|format(comparison.win_rate.delta*100) }}%</span></td>{% elif comparison %}<td>—</td>{% endif %}{% if cmp_vs_avg_available %}<td class="num"><span class="ltr">{% if 'win_rate' in cmp_vs_avg %}{{ "%.1f"|format(cmp_vs_avg.win_rate*100) }}%{% else %}—{% endif %}</span></td>{% endif %}
  </tr>
  <tr>
    <td>Expectancy</td>
    <td class="num {{ 'good' if expectancy_r >= 0.3 else 'bad' if expectancy_r < 0 else '' }}"><span class="ltr">{{ "%+.2f"|format(expectancy_r) }}R</span></td>
    {% if comparison and 'expectancy_r' in comparison %}<td class="num {{ 'delta-up' if comparison.expectancy_r.improving else 'delta-down' }}"><span class="ltr">{{ "%+.2f"|format(comparison.expectancy_r.delta) }}R</span></td>{% elif comparison %}<td>—</td>{% endif %}{% if cmp_vs_avg_available %}<td class="num"><span class="ltr">{% if 'expectancy_r' in cmp_vs_avg %}{{ "%+.2f"|format(cmp_vs_avg.expectancy_r) }}R{% else %}—{% endif %}</span></td>{% endif %}
  </tr>
  <tr>
    <td>Profit Factor</td>
    <td class="num {{ 'good' if profit_factor >= 1.5 else 'bad' if profit_factor < 1 else '' }}"><span class="ltr">{{ "%.2f"|format(profit_factor) }}</span></td>
    {% if comparison and 'profit_factor' in comparison %}<td class="num {{ 'delta-up' if comparison.profit_factor.improving else 'delta-down' }}"><span class="ltr">{{ "%+.2f"|format(comparison.profit_factor.delta) }}</span></td>{% elif comparison %}<td>—</td>{% endif %}{% if cmp_vs_avg_available %}<td class="num"><span class="ltr">{% if 'profit_factor' in cmp_vs_avg %}{{ "%.2f"|format(cmp_vs_avg.profit_factor) }}{% else %}—{% endif %}</span></td>{% endif %}
  </tr>
  <tr>
    <td>ממוצע ניצחון</td>
    <td class="num good"><span class="ltr">+{{ "%.2f"|format(avg_win_r) }}R</span></td>
    <td>—</td>{% if cmp_vs_avg_available %}<td>—</td>{% endif %}
  </tr>
  <tr>
    <td>ממוצע הפסד</td>
    <td class="num bad"><span class="ltr">{{ "%.2f"|format(avg_loss_r) }}R</span></td>
    <td>—</td>{% if cmp_vs_avg_available %}<td>—</td>{% endif %}
  </tr>
  <tr>
    <td>Payoff Ratio</td>
    <td class="num"><span class="ltr">{% if avg_loss_r != 0 %}{{ "%.2f"|format((avg_win_r / avg_loss_r)|abs) }}{% else %}—{% endif %}</span></td>
    <td>—</td>{% if cmp_vs_avg_available %}<td>—</td>{% endif %}
  </tr>
  <tr>
    <td>סה"כ R נטו</td>
    <td class="num {{ 'good' if total_r_net > 0 else 'bad' }}"><span class="ltr">{{ "%+.2f"|format(total_r_net) }}R</span></td>
    {% if comparison and 'total_r_net' in comparison %}<td class="num {{ 'delta-up' if comparison.total_r_net.improving else 'delta-down' }}"><span class="ltr">{{ "%+.2f"|format(comparison.total_r_net.delta) }}R</span></td>{% elif comparison %}<td>—</td>{% endif %}{% if cmp_vs_avg_available %}<td class="num"><span class="ltr">{% if 'total_r_net' in cmp_vs_avg %}{{ "%+.2f"|format(cmp_vs_avg.total_r_net) }}R{% else %}—{% endif %}</span></td>{% endif %}
  </tr>
  <tr>
    <td>רווח ממומש</td>
    <td class="num {{ 'good' if realized_pnl > 0 else 'bad' }}"><span class="ltr">{{ "{:+,.0f}".format(realized_pnl) }}$</span></td>
    <td>—</td>{% if cmp_vs_avg_available %}<td class="num"><span class="ltr">{% if 'realized_pnl' in cmp_vs_avg %}{{ "{:+,.0f}".format(cmp_vs_avg.realized_pnl) }}${% else %}—{% endif %}</span></td>{% endif %}
  </tr>
</table>

{% if best_trade or worst_trade %}
<h3>🏆 עסקאות קיצוניות</h3>
<table class="metrics-table no-break">
  {% if best_trade %}<tr><td>העסקה הטובה ביותר</td><td class="num good"><span class="ltr">{{ best_trade.symbol }} | {{ "%+.2f"|format(best_trade.net_r) }}R | +${{ "%.0f"|format(best_trade.net_pnl) }}</span></td></tr>{% endif %}
  {% if worst_trade %}<tr><td>העסקה הגרועה ביותר</td><td class="num bad"><span class="ltr">{{ worst_trade.symbol }} | {{ "%+.2f"|format(worst_trade.net_r) }}R | ${{ "%.0f"|format(worst_trade.net_pnl) }}</span></td></tr>{% endif %}
</table>
{% endif %}

{# ══ Sprint-18: OPEN BOOK (unrealized) — additive, separate from realized ══
   Reuses ec.get_open_positions_campaign (command-room source). Realized vs
   unrealized strictly separated; ALGO segregated + observation-only
   (DEC-20260511-001 / #8). Floating PnL/R explicitly "לא ממומש". #}
{% if open_book_present %}
<div class="page-break-before"></div>
<h2>{{ open_book_heading }} — <span class="ltr">{{ period_label }}</span></h2>
<p style="font-size:9pt; color:#374151;">
  רווח/הפסד צף ו-R הם <strong>{{ open_book_unrealized_label }}</strong> — אינם נכנסים ל-Win-Rate / Expectancy / PF / Net-R הממומשים.
  &nbsp;|&nbsp; מקור נתונים: <span class="ltr">{{ open_book_data_source }}</span>
</p>

{% if open_book_disc %}
<h3>פוזיציות דיסקרציוניות</h3>
<table class="metrics-table no-break">
  <tr><th>סימול</th><th>כניסה</th><th>נוכחי</th><th>צף ($)</th><th>R מבנה</th><th>R חשבון</th><th>חשיפה</th></tr>
  {% for p in open_book_disc %}
  <tr>
    <td><span class="ltr">{{ p.symbol }}</span>{% if p.price_is_fallback %} ⚠️{% endif %}{% if p.period_label_he %} <span style="font-size:7.5pt;color:#6b7280;">· {{ p.period_label_he }}</span>{% endif %}</td>
    <td class="num"><span class="ltr">${{ "%.2f"|format(p.entry) }}</span></td>
    <td class="num"><span class="ltr">${{ "%.2f"|format(p.current) }}</span></td>
    <td class="num {{ 'good' if p.floating_pnl >= 0 else 'bad' }}"><span class="ltr">{{ "{:+,.0f}".format(p.floating_pnl) }}$</span></td>
    <td class="num"><span class="ltr">{% if p.structure_valid %}{{ "%+.2f"|format(p.structure_r) }}R{% else %}—{% endif %}</span></td>
    <td class="num"><span class="ltr">{% if p.account_valid %}{{ "%+.2f"|format(p.account_r) }}R{% else %}—{% endif %}</span></td>
    <td class="num"><span class="ltr">{{ "%.1f"|format(p.exposure_pct) }}%</span></td>
  </tr>
  {% endfor %}
  <tr>
    <td><strong>סה"כ דיסק'</strong></td><td></td><td></td>
    <td class="num {{ 'good' if open_book_totals.floating_pnl_disc >= 0 else 'bad' }}"><strong><span class="ltr">{{ "{:+,.0f}".format(open_book_totals.floating_pnl_disc) }}$</span></strong></td>
    <td></td><td></td>
    <td class="num"><strong><span class="ltr">{{ "%.1f"|format(open_book_totals.exposure_pct_disc) }}%</span></strong></td>
  </tr>
</table>
{% endif %}

{% if open_book_algo %}
<h3>🟠 ALGO — {{ open_book_algo_observation_label }}</h3>
<table class="metrics-table no-break">
  <tr><th>סימול</th><th>כניסה</th><th>נוכחי</th><th>צף ($)</th><th>R מבנה</th><th>R חשבון</th><th>חשיפה</th></tr>
  {% for p in open_book_algo %}
  <tr>
    <td><span class="ltr">{{ p.symbol }}</span>{% if p.price_is_fallback %} ⚠️{% endif %}{% if p.period_label_he %} <span style="font-size:7.5pt;color:#6b7280;">· {{ p.period_label_he }}</span>{% endif %}</td>
    <td class="num"><span class="ltr">${{ "%.2f"|format(p.entry) }}</span></td>
    <td class="num"><span class="ltr">${{ "%.2f"|format(p.current) }}</span></td>
    <td class="num {{ 'good' if p.floating_pnl >= 0 else 'bad' }}"><span class="ltr">{{ "{:+,.0f}".format(p.floating_pnl) }}$</span></td>
    <td class="num"><span class="ltr">{{ p.structure_r_token }}</span></td>
    <td class="num"><span class="ltr">{% if p.account_valid %}{{ "%+.2f"|format(p.account_r) }}R{% else %}—{% endif %}</span></td>
    <td class="num"><span class="ltr">{{ "%.1f"|format(p.exposure_pct) }}%</span></td>
  </tr>
  {% endfor %}
</table>
<p class="caveat" style="font-size:8.5pt; color:#9ca3af;">{{ open_book_algo_external_caveat }}</p>
{% endif %}

<p style="font-size:8.5pt; color:#374151;">
  מקור מחיר: <span class="ltr">{{ open_book_data_source }}</span>
  {% if open_book_price_fallback_syms %}
  &nbsp;·&nbsp; מחיר לא חי (לפי מחיר כניסה, לא בזמן אמת): <span class="ltr">{{ open_book_price_fallback_syms|join(", ") }}</span>
  {% endif %}
</p>
{% if open_book_mark_delta_text %}
<p style="font-size:8.5pt; color:#374151;"><span class="ltr">{{ open_book_mark_delta_text }}</span></p>
{% endif %}
{# Sprint-19 §2d — open-book period-over-period + vs-average. ALWAYS in the
   open-book section, ALWAYS "(לא ממומש)" (via the source strings), NEVER in
   the realized table. ALGO on its OWN observation-only line. Baseline-pending
   token until N≥3 open_marks-bearing snapshots (#1 — never a fabricated
   mean). #}
{% if obcmp_available %}
{% if obcmp_avg_text %}<p style="font-size:8.5pt; color:#374151;"><span class="ltr">{{ obcmp_avg_text }}</span></p>{% endif %}
{% if obcmp_avg_algo_text %}<p style="font-size:8.5pt; color:#9ca3af;"><span class="ltr">{{ obcmp_avg_algo_text }}</span></p>{% endif %}
{% elif obcmp_baseline_pending %}
<p style="font-size:8.5pt; color:#374151;"><span class="ltr">{{ obcmp_baseline_pending }}</span></p>
{% endif %}
{% endif %}

{# ══ PAGE 3: Execution Quality ════════════════════════════════════════════== #}
<div class="page-break-before"></div>
<h2>⚙️ איכות ביצוע</h2>

{% if chart_setup_perf %}
<div class="chart-wrap">
  <img src="{{ chart_setup_perf }}" alt="ביצועי Setups" class="report-chart">
</div>
{% endif %}

<table class="metrics-table no-break">
  <tr><th>מדד</th><th>ערך</th><th>סטטוס</th></tr>
  <tr>
    <td>שיעור חסרי סטופ התחלתי</td>
    <td class="num"><span class="ltr">{{ "%.1f"|format(missing_stop_rate*100) }}%</span></td>
    <td>{% if missing_stop_rate < 0.1 %}✅ תקין{% elif missing_stop_rate < 0.25 %}⚠️ לשיפור{% else %}🔴 חמור{% endif %}</td>
  </tr>
  <tr>
    <td>שיעור פוזיציות Oversized</td>
    <td class="num"><span class="ltr">{{ "%.1f"|format(oversized_rate*100) }}%</span></td>
    <td>{% if oversized_rate < 0.15 %}✅ תקין{% elif oversized_rate < 0.30 %}⚠️ לשיפור{% else %}🔴 חמור{% endif %}</td>
  </tr>
  <tr>
    <td>R ממוצע ליום אחזקה</td>
    <td class="num"><span class="ltr">{{ "%.3f"|format(avg_r_per_day) }}R/day</span></td>
    <td>{% if avg_r_per_day > 0.05 %}✅{% elif avg_r_per_day > 0 %}🟡{% else %}🔴{% endif %}</td>
  </tr>
  {% if risk_adherence_rate is not none %}
  <tr>
    <td>ציות להמלצות סיכון</td>
    <td class="num"><span class="ltr">{{ "%.1f"|format(risk_adherence_rate*100) }}%</span></td>
    <td>{% if risk_adherence_rate >= 0.7 %}✅{% elif risk_adherence_rate >= 0.5 %}⚠️{% else %}🔴{% endif %}</td>
  </tr>
  {% endif %}
</table>

{% if dev_score is not none %}
<h3>ציון פיתוח סוחר</h3>
<div class="score-bar-outer">
  <div class="score-bar-inner" style="width: {{ dev_score }}%;"></div>
</div>
<p style="font-size:9pt; color:#374151; margin-top:1mm;">
  <strong>{{ dev_score }}/100</strong> — {{ dev_label }}
  {% if dev_breakdown %}
  &nbsp;|&nbsp;
  <span class="ltr">תהליך: {{ dev_breakdown.process }}, Edge: {{ dev_breakdown.edge }}, סיכון: {{ dev_breakdown.risk }}, ביצוע: {{ dev_breakdown.execution }}</span>
  {% endif %}
</p>
{% endif %}

{# Setup breakdown table #}
{% if setup_breakdown %}
<h3>📋 פירוט לפי אסטרטגיה</h3>
<table class="league-table no-break">
  <tr><th>Setup</th><th>קמפיינים</th><th>Net R</th><th>Win%</th><th>Avg R</th><th>PF</th></tr>
  {% for setup, stats in setup_breakdown.items() %}
  <tr>
    <td><span class="ltr">{{ setup }}</span></td>
    <td>{{ stats.count }}</td>
    <td class="{{ 'good' if stats.net_r > 0 else 'bad' }}"><span class="ltr">{{ "%+.2f"|format(stats.net_r) }}R</span></td>
    <td><span class="ltr">{{ "%.1f"|format(stats.win_rate*100) }}%</span></td>
    <td><span class="ltr">{{ "%+.2f"|format(stats.avg_r) }}R</span></td>
    <td><span class="ltr">{{ "%.2f"|format(stats.profit_factor) }}</span></td>
  </tr>
  {% endfor %}
</table>
{% endif %}

{# ══ PAGE 4: System Health ════════════════════════════════════════════════== #}
<div class="page-break-before"></div>
<h2>🏥 בריאות מערכת</h2>
<ul class="health-list">
  <li>{{ sync_status }}</li>
  <li>{{ nav_freshness_label }}</li>
  <li>{{ risk_monitor_status }}</li>
  <li>{{ report_service_status }}</li>
</ul>

{# ══ PAGE 5: Coaching ════════════════════════════════════════════════════=== #}
<h2>🎓 Minervini Coaching</h2>
{% if coaching_insights %}
{% for insight in coaching_insights[:3] %}
<div class="coaching-box">{{ insight }}</div>
{% endfor %}
{% else %}
<div class="coaching-box">אין תובנות זמינות לשבוע זה.</div>
{% endif %}

<h3>3 פעולות לשבוע הבא</h3>
<div class="coaching-box">
  {% if missing_stop_rate > 0.15 %}
  <div class="action-item">לוודא שכל BUY חדש מוזן עם initial stop לפני פתיחת פוזיציה.</div>
  {% endif %}
  {% if oversized_rate > 0.20 %}
  <div class="action-item">לבדוק sizing בפוזיציות הבאות — {{ "%.0f"|format(oversized_rate*100) }}% מעל 125% מ-Target Risk.</div>
  {% endif %}
  {% if expectancy_r < 0.3 and campaigns_closed > 0 %}
  <div class="action-item">להעלות סלקטיביות — Expectancy של {{ "%+.2f"|format(expectancy_r) }}R לא מצדיק את ה-drawdown.</div>
  {% endif %}
  {% if risk_adherence_rate is not none and risk_adherence_rate < 0.6 %}
  <div class="action-item">לעקוב אחרי המלצות Adaptive Risk — ציות של {{ "%.0f"|format(risk_adherence_rate*100) }}% בלבד.</div>
  {% endif %}
  {% if not missing_stop_rate > 0.15 and not oversized_rate > 0.20 and not (expectancy_r < 0.3 and campaigns_closed > 0) %}
  <div class="action-item">להמשיך בשמירת המשמעת — התהליך תקין השבוע.</div>
  {% endif %}
</div>

<p style="font-size:7.5pt; color:#9ca3af; margin-top:6mm; text-align:center; direction:ltr;">
  Sentinel Trading Report | Generated {{ generated_at[:19] }} | For internal use only
</p>

